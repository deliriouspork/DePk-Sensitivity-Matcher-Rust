import { ComboBox, LineEdit } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Sensitivity Matcher";
    width: 391px;
    height: 240px;

    // Exposed properties — Rust reads/writes these
    in-out property <string> sens-text: "4.0";
    in-out property <string> yaw-text: "0.022";
    in-out property <string> speed-text: "1";
    in-out property <string> increment-text: "?";
    in-out property <int> preset-index: 0;

    // Callbacks — Rust connects to these
    callback sens-changed(string);
    callback yaw-changed(string);
    callback speed-changed(string);
    callback preset-changed(int);

    // Clicking empty gotta deselect man
    dummy-focus := FocusScope {
        x: 0; y: 0; width: 0px; height: 0px;
    }

    TouchArea {
        x: 0; y: 0;
        width: root.width;
        height: root.height;
        clicked => { dummy-focus.focus(); }
    }

    // --- Row 1: preset label + combobox ---

    Text {
        x: 10px; y: 14px;
        text: "Select preset yaw:";
    }

    ComboBox {
        x: 130px; y: 0px;
        width: 181px; height: 32px;
        model: [
            "Quake/Source/Apex",
            "Overwatch/Valorant/CoD",
            "Rainbow Six Siege",
            "Fortnite",
            "Battlefield/Frostbite",
            "Custom"
        ];
        current-index <=> root.preset-index;
        selected => {
            root.preset-changed(self.current-index);
        }
    }

    // --- Row 2: sens / yaw / increment inputs ---

    LineEdit {
        x: 10px; y: 40px;
        width: 91px; height: 32px;
        text <=> root.sens-text;
        edited => {
            root.sens-text = self.text;
            root.sens-changed(self.text);
        }
    }

    LineEdit {
        x: 150px; y: 40px;
        width: 91px; height: 32px;
        text <=> root.yaw-text;
        edited => {
            root.yaw-text = self.text;
            root.yaw-changed(self.text);
        }
    }

    LineEdit {
        x: 290px; y: 40px;
        width: 91px; height: 32px;
        text: root.increment-text;
        read-only: true;
    }

    // --- Row 3: field labels ---

    Text {
        x: 10px; y: 80px;
        width: 91px;
        text: "Sens";
        horizontal-alignment: center;
    }

    Text {
        x: 150px; y: 78px;
        width: 91px;
        text: "Yaw";
        horizontal-alignment: center;
    }

    Text {
        x: 290px; y: 80px;
        width: 91px;
        text: "Increment";
        horizontal-alignment: center;
    }

    // --- Divider line ---

    Rectangle {
        x: 0px; y: 108px;
        width: 391px; height: 1px;
        background: #aaa;
    }

    // --- Optional testing parameters ---

    Text {
        x: 100px; y: 120px;
        width: 191px;
        text: "Optional Testing Parameters";
        horizontal-alignment: center;
    }

    Text {
        x: 10px; y: 163px;
        width: 131px;
        text: "Speed multiplier:";
        horizontal-alignment: right;
    }

    LineEdit {
        x: 150px; y: 150px;
        width: 91px; height: 32px;
        text <=> root.speed-text;
        edited => {
            root.speed-text = self.text;
            root.speed-changed(self.text);
        }
    }

    // --- Footer ---

    Text {
        x: 250px; y: 220px;
        width: 131px;
        text: "Created by DePk";
        horizontal-alignment: right;
    }
}
